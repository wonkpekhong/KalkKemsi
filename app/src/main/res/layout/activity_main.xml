<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:gravity="bottom|end"
        android:padding="24dp"
        android:text="0"
        android:textColor="#000000"
        android:textSize="60sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:text="MC" style="@style/BlueBtn" />
            <Button android:text="MR" style="@style/BlueBtn" />
            <Button android:text="M-" style="@style/BlueBtn" />
            <Button android:text="M+" style="@style/BlueBtn" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:text="C" style="@style/BlueBtn" />
            <Button android:text="+/-" style="@style/BlueBtn" />
            <Button android:text="%" style="@style/BlueBtn" />
            <Button android:text="÷" style="@style/BlueBtn" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:text="7" style="@style/WhiteBtn" />
            <Button android:text="8" style="@style/WhiteBtn" />
            <Button android:text="9" style="@style/WhiteBtn" />
            <Button android:text="x" style="@style/BlueBtn" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:text="4" style="@style/WhiteBtn" />
            <Button android:text="5" style="@style/WhiteBtn" />
            <Button android:text="6" style="@style/WhiteBtn" />
            <Button android:text="-" style="@style/BlueBtn" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:text="1" style="@style/WhiteBtn" />
            <Button android:text="2" style="@style/WhiteBtn" />
            <Button android:text="3" style="@style/WhiteBtn" />
            <Button android:text="+" style="@style/BlueBtn" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:text="0" style="@style/WhiteBtn" />
            <Button android:text="00" style="@style/WhiteBtn" />
            <Button android:text="000" style="@style/WhiteBtn" />
            <Button android:text="," style="@style/WhiteBtn" />
            <Button android:text="=" style="@style/BlueBtn" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
